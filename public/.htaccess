<IfModule mod_rewrite.c>
  RewriteEngine On

  # Enforce HTTPS + non-www canonical host in one redirect
  RewriteCond %{HTTPS} !=on [OR]
  RewriteCond %{HTTP_HOST} ^www\.kaliadziuk\.lt$ [NC]
  RewriteRule ^(.*)$ https://kaliadziuk.lt/$1 [L,R=301]

  # Avoid duplicate content for index.html paths
  RewriteRule ^index\.html$ /lt/ [L,R=301]
  RewriteRule ^(lt|en)/index\.html$ /$1/ [L,R=301]

  # Normalize trailing slash for non-file paths
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} !\.[a-zA-Z0-9]{2,5}$
  RewriteCond %{REQUEST_URI} !/$
  RewriteRule ^(.*)$ /$1/ [L,R=301]

  # If the request is for an existing file or directory, serve it
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Otherwise, route everything to index.html for React Router
  RewriteRule ^ index.html [L]
</IfModule>

<IfModule mod_mime.c>
  AddDefaultCharset UTF-8
  AddCharset UTF-8 .html .htm
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType application/x-javascript "access plus 1 year"
  ExpiresByType image/avif "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Content-Security-Policy "frame-ancestors 'self' https://challenges.cloudflare.com https://js.stripe.com https://pay.google.com"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=*, usb=()"
  <FilesMatch "\.(?:css|js|mjs|png|jpe?g|webp|avif|svg|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
