{
  "name": "kaliadziuk-site",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/sync-uploads.mjs && node ./node_modules/vite/bin/vite.js",
    "build": "npm run build:seo",
    "build:fast": "node scripts/generate-image-variants.mjs && node scripts/sync-uploads.mjs && node ./node_modules/vite/bin/vite.js build && node scripts/copy-branding.mjs",
    "build:prerender": "node scripts/prerender.mjs",
    "build:seo": "node scripts/generate-image-variants.mjs && node scripts/sync-uploads.mjs && node ./node_modules/vite/bin/vite.js build && node scripts/prerender.mjs && node scripts/copy-branding.mjs",
    "thumbs:avatars": "node scripts/generate-avatar-thumbs.mjs",
    "images:optimize": "node scripts/generate-image-variants.mjs",
    "sync:uploads": "node scripts/sync-uploads.mjs",
    "preview": "node ./node_modules/vite/bin/vite.js preview"
  },
  "dependencies": {
    "@stripe/react-stripe-js": "^5.6.1",
    "@stripe/stripe-js": "^8.9.0",
    "@supabase/supabase-js": "^2.89.0",
    "aos": "^2.3.4",
    "i18next": "^25.7.3",
    "keen-slider": "^6.8.6",
    "lucide-react": "^0.564.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-i18next": "^16.5.1",
    "react-router-dom": "^7.11.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.2",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "puppeteer": "^24.36.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.10",
    "vite": "^6.4.1"
  }
}
